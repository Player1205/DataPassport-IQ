# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=DataPassport

# ── Auth ──────────────────────────────────────────────────────
# IMPORTANT: Replace with a cryptographically random string (min 64 chars)
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# ── AI (Google Gemini) ───────────────────────────────────────
LLM_API_KEY=YOUR_GEMINI_API_KEY
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_MODEL=gemini-flash-latest

# ── Blockchain (Base Sepolia) ────────────────────────────────
CHAIN_RPC_URL=https://sepolia.base.org
CHAIN_ID=84532
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Your deployer wallet private key (NEVER commit this)
BLOCKCHAIN_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
